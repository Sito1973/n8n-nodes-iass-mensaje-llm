{
  "name": "n8n-nodes-iass-mensaje-llm",
  "version": "0.1.0",
  "description": "Nodo personalizado para enviar mensajes al servicio LLM con contexto completo del cliente",
  "keywords": [
    "n8n-community-node-package",
    "llm",
    "whatsapp",
    "chatbot",
    "ai"
  ],
  "license": "MIT",
  "homepage": "",
  "author": {
    "name": "IASS",
    "email": ""
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "lint": "tslint -p tsconfig.json -c tslint.json",
    "lintfix": "tslint --fix -p tsconfig.json -c tslint.json"
  },
  "files": [
    "dist"
